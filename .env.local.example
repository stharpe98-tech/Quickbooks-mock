# Copy this file to .env.local and fill in values from your Supabase project.
# Project Settings > API in the Supabase dashboard.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used for the magic-link redirect. In production this is your Vercel URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Teller (optional — for bank connections) ──────────────────────────
# Sign up at https://teller.io. Settings can also live in the in-app
# settings page if you'd rather store them in the DB.
TELLER_APPLICATION_ID=
TELLER_CERTIFICATE=
TELLER_PRIVATE_KEY=
# sandbox | development | production
TELLER_ENV=sandbox

# ─── Vercel cron (optional) ─────────────────────────────────────────────
# If set, the cron route requires this bearer token. Vercel sends it
# automatically when defined as an env var on your project.
CRON_SECRET=
